PORT=3001
NODE_ENV=development

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# SQLite database path (absolute path recommended in production)
# DB_PATH=/app/data/voicemybook.db

# TTS (Kokoro — no API key needed, model downloaded on first run)
TTS_CONCURRENCY=3
TTS_CHUNK_SIZE=1000
TTS_VOICE=af_heart

# Cleanup (hours; 0 = never)
CLEANUP_AFTER_HOURS=24
